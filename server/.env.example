# ═══════════════════════════════════════════
# Aarogya AI Server — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════

# ── App ──
NODE_ENV=development
PORT=5000

# ── Database ──
MONGODB_URI=mongodb://localhost:27017/aarogya

# ── JWT Authentication ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ── Google Gemini AI ──
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── CORS ──
CORS_ORIGIN=http://localhost:3002,http://localhost:3003,http://localhost:5173

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── URLs ──
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3002

# ── Google OAuth (optional) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth (optional) ──
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Grocery Concierge / n8n (optional) ──
N8N_GROCERY_WEBHOOK=
N8N_API_KEY=
BLINKIT_AFFILIATE_TAG=
AMAZON_AFFILIATE_TAG=
