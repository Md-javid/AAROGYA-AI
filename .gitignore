# ═══════════════════════════════════════════
# ELLAURA — Git Ignore
# ═══════════════════════════════════════════

# ── Dependencies ──
node_modules/
server/node_modules/
client/node_modules/

# ── Build output ──
dist/
build/
server/dist/
client/dist/

# ── Environment files (NEVER commit secrets) ──
.env
.env.local
.env.production
.env.*.local
server/.env
client/.env

# ── Lock files (optional: remove if you want reproducible builds) ──
package-lock.json
server/package-lock.json
client/package-lock.json

# ── Python ──
ml_model/__pycache__/
ml_model/*.pyc
ml_model/.venv/
ml_model/venv/
ml_model/*.pkl
ml_model/*.joblib
*.egg-info/

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── OS files ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Testing / Coverage ──
coverage/
.nyc_output/

# ── Misc ──
.cache/
*.tgz
